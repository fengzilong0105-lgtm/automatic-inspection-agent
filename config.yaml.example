mode: remote
setup_completed: false
active_service_id: null

hosts:
  - id: prod-01
    name: 生产服务器
    ssh:
      host: 192.168.1.100
      port: 22
      user: deploy
      key_file: C:/keys/deploy.pem

services: []

discovery:
  auto_scan_on_setup: true
  rescan_interval_hours: 0

monitor:
  interval_seconds: 60
  health_fail_threshold: 3
  log_error_window_minutes: 5
  log_error_threshold: 5

llm:
  default:
    provider: openai
    base_url: https://api.openai.com/v1
    api_key: ${LLM_API_KEY}
    model: gpt-4o-mini
    temperature: 0.2
    max_tokens: 4096
  routing:
    chat_qa:
      model: gpt-4o-mini
      max_tokens: 2048
    diagnosis:
      model: gpt-4o-mini
      max_tokens: 4096
  ollama_base_url: http://localhost:11434

feishu:
  enabled: false
  app_id: ""
  app_secret: ""
  alert_chat_id: ""
  bot:
    command_enabled: false   # 启用飞书 @机器人 只读指令
    command_chat_id: ""     # 留空则使用 alert_chat_id
    require_at_mention: true

web:
  enabled: true
  host: 0.0.0.0
  port: 8765
  auth_token: ${SENTINEL_WEB_TOKEN}

autonomy:
  max_restart_per_15min: 3
  write_allow_all_paths: true
  # 仅当 write_allow_all_paths: false 时，下面的路径模式才会生效
  # write_path_whitelist:
  #   - /etc/systemd/system/*.service

ops_report:
  auto_draft_on_incident: false
  auto_publish: false
  initiator_default: 运维值班
  feishu:
    archive_folder_token: ""   # 飞书云文档归档文件夹 token
    tenant_subdomain: ""       # 企业子域名，如 mycompany → https://mycompany.feishu.cn/docx/...
    bitable_app_token: ""      # M3 多维表格
    bitable_table_id: ""
    notify_chat_id: ""         # M3 发布通知群，留空则复用 feishu.alert_chat_id

data_dir: ./data

ops_report:
  initiator_default: 运维值班
